# Required
PLATFORM_JWT_SECRET=replace-with-32-plus-char-secret

# Runtime
NODE_ENV=development
PORT=3000
IDENTITY_PORT=3001
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000

# SQLite paths (local defaults)
IDENTITY_DB_PATH=./platform/identity-service/identity.db
DATA_DB_PATH=./platform/data-service/data.db

# Development-only
DEV_SEED=false

# Railway production example (when volume is mounted at /data)
# IDENTITY_DB_PATH=/data/identity.db
# DATA_DB_PATH=/data/data.db
